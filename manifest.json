{
  "manifest_version": 3,
  "name": "股票神器Stocks（股票盯盘助手） - 摸鱼看盘小帮手",
  "description": "让股票盯盘更轻松。支持指数查看、自选股关注、目标价提醒和浏览器通知，适合上班时快速看盘并及时接收提醒。。",
  "version": "1.2.0",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://searchapi.eastmoney.com/*",
    "https://push2.eastmoney.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "股票神器Stocks",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  }
}
