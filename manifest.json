{
  "manifest_version": 3,
  "name": "盯盘助手 - 摸鱼看盘小帮手（财神保佑一直红）",
  "description": "摸鱼也能快速看盘，愿你自选一直红。支持指数查看、股票关注、目标价提醒和浏览器通知，适合上班场景快速盯盘。",
  "version": "1.1.6",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://searchapi.eastmoney.com/*",
    "https://push2.eastmoney.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "盯盘助手",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  }
}
