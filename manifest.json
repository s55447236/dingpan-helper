{
  "manifest_version": 3,
  "name": "盯盘助手",
  "description": "关注指数和股票，设置目标价提醒并接收浏览器通知。",
  "version": "1.1.1",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://searchapi.eastmoney.com/*",
    "https://push2.eastmoney.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "盯盘助手",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  }
}
