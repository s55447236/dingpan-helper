.pray-page {
  padding-bottom: 48rpx;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #0f172a;
}

.sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.altar-card {
  position: relative;
  overflow: hidden;
  min-height: 980rpx;
  background: linear-gradient(180deg, #fff7ed 0%, #ffffff 52%, #fff 100%);
}

.deity-name {
  text-align: center;
  font-size: 36rpx;
  font-weight: 800;
  color: #991b1b;
}

.deity-stage {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.arrow-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #991b1b;
  font-size: 46rpx;
  line-height: 56rpx;
  padding: 0;
}

.deity-video {
  width: 100%;
  height: 470rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #fff1e6;
}

.deity-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 470rpx;
  border-radius: 20rpx;
  background: radial-gradient(circle at 50% 28%, #fff7ed 0%, #fed7aa 46%, #991b1b 100%);
  color: #fff7ed;
  overflow: hidden;
}

.deity-seal {
  width: 150rpx;
  height: 150rpx;
  border-radius: 999rpx;
  border: 6rpx solid rgba(255, 247, 237, 0.84);
  text-align: center;
  font-size: 76rpx;
  font-weight: 900;
  line-height: 142rpx;
}

.deity-placeholder-name {
  margin-top: 28rpx;
  font-size: 44rpx;
  font-weight: 900;
}

.blessing {
  min-height: 72rpx;
  margin: 22rpx 0;
  text-align: center;
  color: #7f1d1d;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 700;
}

.offering-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.offering-slot {
  position: relative;
  min-height: 178rpx;
  border-radius: 20rpx;
  padding: 18rpx 14rpx;
  box-sizing: border-box;
}

.empty-slot {
  border: 2rpx dashed #f59e0b;
  background: #fffbeb;
  color: #d97706;
  font-size: 48rpx;
  line-height: 130rpx;
}

.filled {
  background: #fff7ed;
  border: 2rpx solid #fed7aa;
}

.slot-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: #fee2e2;
  color: #dc2626;
  font-size: 28rpx;
  line-height: 38rpx;
  padding: 0;
}

.slot-name {
  padding-right: 34rpx;
  font-size: 25rpx;
  font-weight: 800;
  color: #111827;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.slot-meta,
.slot-quote,
.result-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.slot-meta {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 22rpx;
}

.slot-quote {
  margin-top: 12rpx;
  justify-content: space-between;
  font-size: 23rpx;
  font-weight: 800;
}

.burner {
  display: block;
  width: 300rpx;
  height: 190rpx;
  margin: 34rpx auto 0;
}

.incense-btn {
  width: 240rpx;
  margin: 4rpx auto 0;
}

.incense-count {
  margin-top: 18rpx;
  text-align: center;
  color: #92400e;
  font-size: 24rpx;
}

.overlay {
  position: fixed;
  inset: 0;
  z-index: 20;
}

.overlay-bg {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.42);
}

.search-panel {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 36rpx;
  max-height: 78vh;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 800;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 32rpx;
  line-height: 50rpx;
  padding: 0;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #f8fafc;
}

.search-box input {
  flex: 1;
  font-size: 28rpx;
}

.search-icon {
  color: #94a3b8;
  font-size: 32rpx;
}

.result-list {
  margin-top: 14rpx;
  max-height: 760rpx;
  overflow: auto;
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.result-name {
  font-size: 28rpx;
  font-weight: 700;
}

.result-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.small-btn {
  min-width: 116rpx;
  height: 58rpx;
  font-size: 24rpx;
  line-height: 58rpx;
  padding: 0 22rpx;
}
