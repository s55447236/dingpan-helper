.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #0f172a;
}

.sub,
.updated {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.indexes {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.index-item {
  min-height: 128rpx;
  padding: 18rpx 10rpx;
  border-radius: 18rpx;
  background: #f8fbff;
  border: 1rpx solid #dbeafe;
  box-sizing: border-box;
  text-align: center;
}

.index-name {
  font-size: 24rpx;
  color: #111827;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.index-price {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.index-change {
  margin-top: 4rpx;
  font-size: 23rpx;
}

.search-card {
  padding-bottom: 10rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #f8fafc;
}

.search-box input {
  flex: 1;
  font-size: 28rpx;
}

.search-icon {
  color: #94a3b8;
  font-size: 32rpx;
}

.clear-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #475569;
  font-size: 30rpx;
  line-height: 42rpx;
  padding: 0;
}

.search-results {
  margin-top: 12rpx;
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.result-name {
  font-size: 28rpx;
  font-weight: 700;
}

.result-meta,
.stock-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.small-btn {
  min-width: 116rpx;
  height: 58rpx;
  font-size: 24rpx;
  line-height: 58rpx;
  padding: 0 22rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
}

.count {
  color: #94a3b8;
  font-size: 24rpx;
}

.stock-card {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.stock-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.stock-info {
  min-width: 0;
}

.stock-name {
  font-size: 30rpx;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.quote-box {
  min-width: 150rpx;
  text-align: right;
}

.price {
  font-size: 34rpx;
  font-weight: 900;
}

.percent {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.alert-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.alert-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 48rpx;
  padding: 0 8rpx 0 18rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 22rpx;
}

.alert-tag.hit {
  background: #fef2f2;
  color: #dc2626;
  font-weight: 800;
}

.alert-tag button {
  width: 38rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: transparent;
  color: inherit;
  font-size: 26rpx;
  line-height: 34rpx;
  padding: 0;
}

.target-editor {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 18rpx;
  background: #f8fafc;
}

.target-editor input {
  flex: 1;
  height: 58rpx;
  font-size: 26rpx;
}

.stock-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
  margin-top: 16rpx;
}
